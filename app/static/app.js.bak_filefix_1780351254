/* =================================================================
   PCG-MAS · static frontend — real backend wiring
   ================================================================= */

(function () {
  'use strict';

  // ---------- Theme toggle ----------
  (function initTheme() {
    const KEY = 'pcg-theme';
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    const apply = (mode) => {
      if (mode === 'system') root.removeAttribute('data-theme');
      else root.setAttribute('data-theme', mode);
      try { localStorage.setItem(KEY, mode); } catch (_) {}
      if (btn) btn.title = 'Theme: ' + mode + ' (click to cycle)';
    };
    let saved = 'system';
    try { saved = localStorage.getItem(KEY) || 'system'; } catch (_) {}
    apply(saved);
    if (btn) btn.addEventListener('click', () => {
      const cur = (localStorage.getItem(KEY) || 'system');
      const next = cur === 'system' ? 'light' : (cur === 'light' ? 'dark' : 'system');
      apply(next);
    });
  })();

  // ---------- Tabs ----------
  function showTab(name) {
    document.querySelectorAll('.tab-panel[data-tab]').forEach(p => {
      if (p.getAttribute('data-tab') === name) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    document.querySelectorAll('.tabs button[data-tab]').forEach(b => {
      b.setAttribute('aria-selected',
        b.getAttribute('data-tab') === name ? 'true' : 'false');
    });
    document.querySelectorAll('.header-nav a[data-tab]').forEach(a => {
      a.classList.toggle('is-active', a.getAttribute('data-tab') === name);
    });
  }
  (function initTabs() {
    document.querySelectorAll('.tabs button[data-tab]').forEach(b => {
      b.addEventListener('click', () => showTab(b.getAttribute('data-tab')));
    });
    document.querySelectorAll('[data-tab]:not(button)').forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const name = a.getAttribute('data-tab');
        showTab(name);
        const panel = document.querySelector('.tab-panel[data-tab="' + name + '"]');
        if (panel) {
          const top = panel.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });
    const hash = (location.hash || '').replace('#tab-', '');
    if (hash) showTab(hash);
  })();

  // ---------- Backend hint ----------
  (function initBackendHint() {
    const select = document.getElementById('backend-select');
    const apiKey = document.getElementById('api-key');
    const hint   = document.getElementById('backend-hint');
    if (!select || !apiKey || !hint) return;
    const HINTS = {
      openai:    'Get a key at platform.openai.com/api-keys (starts with sk-…)',
      anthropic: 'Get a key at console.anthropic.com/settings/keys (starts with sk-ant-…)',
      deepseek:  'Get a key at platform.deepseek.com (starts with sk-…)',
      hf:        'Use a HF read token from huggingface.co/settings/tokens (starts with hf_…)',
    };
    const update = () => {
      const v = (select.value || '').toLowerCase();
      let provider = 'openai';
      if (v.includes('anthropic')) provider = 'anthropic';
      else if (v.includes('deepseek')) provider = 'deepseek';
      else if (v.includes('hf inference')) provider = 'hf';
      apiKey.placeholder = 'Paste your ' + (provider === 'hf' ? 'hugging face' : provider) + ' key…';
      hint.textContent = HINTS[provider];
    };
    select.addEventListener('change', update);
    update();
  })();

  // ---------- Top-k slider ----------
  (function initSlider() {
    const slider = document.getElementById('topk');
    const out    = document.getElementById('topk-out');
    if (!slider || !out) return;
    const update = () => { out.value = slider.value; };
    slider.addEventListener('input', update);
    update();
  })();

  // ---------- Segmented input source ----------
  (function initSegmented() {
    const buttons = document.querySelectorAll('.segmented .seg-btn');
    const fieldText = document.getElementById('field-context');
    const fieldUrl  = document.getElementById('field-url');
    const fieldFile = document.getElementById('field-file');
    if (!buttons.length) return;
    const show = (mode) => {
      buttons.forEach(b => {
        const active = b.getAttribute('data-mode') === mode;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      if (fieldText) fieldText.toggleAttribute('hidden', mode !== 'text');
      if (fieldUrl)  fieldUrl.toggleAttribute('hidden', mode !== 'url');
      if (fieldFile) fieldFile.toggleAttribute('hidden', mode !== 'file');
      window.__pcgInputMode = mode;
    };
    buttons.forEach(b => {
      b.addEventListener('click', () => show(b.getAttribute('data-mode')));
    });
    show('text');
  })();

  // ---------- File browser (Live Run + Results, robust) ----------
  function wireFileBrowser(browseBtnId, fileInputId, hintId) {
    const btn = document.getElementById(browseBtnId);
    const input = document.getElementById(fileInputId);
    const hint = hintId ? document.getElementById(hintId) : null;

    if (!input) {
      console.warn('file input not found:', fileInputId);
      return;
    }

    const defaultHint = '.pdf, .docx, .csv, .xlsx, .md, .txt, .json, .html';

    const setHint = () => {
      const f = input.files && input.files[0];
      const drop = input.closest('.dropzone');
      const fallback = drop && drop.querySelector('.dropzone-hint');
      const target = hint || fallback;
      if (target) target.textContent = f ? f.name : defaultHint;
    };

    // Explicit custom button. This keeps the UI pretty.
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Must be called directly inside the user click handler.
        // Safari/Chrome allow this when input is present in DOM and not disabled.
        input.click();
      });
    } else {
      console.warn('browse button not found:', browseBtnId);
    }

    // Native input fallback. Even if JS click delegation fails, the browser's
    // own "Choose File" button should still work.
    input.addEventListener('change', setHint);

    // Drag/drop fallback.
    const drop = input.closest('.dropzone');
    if (drop) {
      drop.addEventListener('dragover', (e) => {
        e.preventDefault();
        drop.classList.add('is-dragover');
      });

      drop.addEventListener('dragleave', () => {
        drop.classList.remove('is-dragover');
      });

      drop.addEventListener('drop', (e) => {
        e.preventDefault();
        drop.classList.remove('is-dragover');

        if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) {
          input.files = e.dataTransfer.files;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    }
  }

  (function initFileBrowsers() {
    wireFileBrowser('file-browse', 'file', 'dropzone-hint');
    wireFileBrowser('results-file-browse', 'results-file', 'results-dropzone-hint');
  })();

  // ---------- Examples ----------
  (function initExampleLoader() {
    const select = document.getElementById('example-select');
    const q = document.getElementById('question');
    const c = document.getElementById('context');
    if (!select || !q || !c) return;
    fetch('/api/examples').then(r => r.json()).then((examples) => {
      window.__pcgExamples = examples || [];
    }).catch(() => { window.__pcgExamples = []; });
    select.addEventListener('change', () => {
      const idx = parseInt(select.value, 10);
      if (Number.isNaN(idx)) return;
      const ex = (window.__pcgExamples || [])[idx];
      if (!ex) return;
      q.value = ex.question || '';
      c.value = ex.context || '';
      // Switch to text mode in case user is on URL/file
      const textBtn = document.querySelector('.seg-btn[data-mode="text"]');
      if (textBtn) textBtn.click();
    });
  })();

  // ---------- Helpers: state ----------
  function setChipState(channel, state) {
    const chip = document.querySelector('.status-chip[data-channel="' + channel + '"]');
    if (chip) chip.setAttribute('data-state', state);
  }
  function setNodeState(node, state) {
    const g = document.querySelector('.node[data-node="' + node + '"]');
    if (g) g.setAttribute('data-state', state);
  }
  function setEdgeState(idx, state) {
    const g = document.querySelector('.edge[data-edge="' + idx + '"]');
    if (g) g.setAttribute('data-state', state);
  }
  function resetPipeline() {
    ['V_H', 'V_pi', 'V_gamma', 'V_entail'].forEach(c => {
      setChipState(c, 'idle'); setNodeState(c, 'idle');
    });
    [0, 1, 2, 3, 4].forEach(i => setEdgeState(i, 'idle'));
    const ch = document.getElementById('cert-hash');
    if (ch) ch.textContent = 'SHA-256';
    const banner = document.getElementById('result-banner');
    if (banner) banner.setAttribute('hidden', '');
  }

  // Channel-to-edge map for animating the connecting line BEFORE the next node
  const CHANNEL_EDGE = {
    'V_H':      { incoming: 0, outgoing: 1 },
    'V_pi':     { incoming: 1, outgoing: 2 },
    'V_gamma':  { incoming: 2, outgoing: 3 },
    'V_entail': { incoming: 3, outgoing: 4 },
  };

  function applyChannelEvent(ev) {
    const c = ev.channel;
    const s = ev.state;
    const map = CHANNEL_EDGE[c];
    setChipState(c, s);
    setNodeState(c, s);
    if (map) {
      if (s === 'pending') setEdgeState(map.incoming, 'pending');
      else                 setEdgeState(map.incoming, s);
    }
  }

  // ---------- Upload helper ----------
  async function uploadIfNeeded() {
    const mode = window.__pcgInputMode || 'text';
    if (mode !== 'file') return '';
    const input = document.getElementById('file');
    if (!input || !input.files || !input.files[0]) {
      throw new Error('No file selected.');
    }
    const fd = new FormData();
    fd.append('file', input.files[0]);
    const r = await fetch('/api/upload', { method: 'POST', body: fd });
    if (!r.ok) {
      const t = await r.text();
      throw new Error('upload failed: ' + r.status + ' ' + t);
    }
    const data = await r.json();
    return data.file_path;
  }

  function buildRunBody(extraFilePath) {
    const mode = window.__pcgInputMode || 'text';
    return {
      mode: mode,
      question: (document.getElementById('question') || {}).value || '',
      context:  (document.getElementById('context')  || {}).value || '',
      url:      (document.getElementById('url')      || {}).value || '',
      file_path: extraFilePath || '',
      backend_label: (document.getElementById('backend-select') || {}).value || '',
      api_key: (document.getElementById('api-key') || {}).value || '',
      replay_check: (document.getElementById('replay-check') || {}).checked || false,
      top_k: parseInt((document.getElementById('topk') || {}).value || '6', 10),
    };
  }

  // ---------- SSE parser for fetch streaming ----------
  async function streamSSE(response, handlers) {
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      // Each SSE event is terminated by a blank line
      let idx;
      while ((idx = buf.indexOf('\n\n')) >= 0) {
        const block = buf.slice(0, idx);
        buf = buf.slice(idx + 2);
        let evName = 'message';
        let dataLine = '';
        block.split('\n').forEach(line => {
          if (line.startsWith('event:')) evName = line.slice(6).trim();
          else if (line.startsWith('data:')) dataLine += line.slice(5).trim();
        });
        if (!dataLine) continue;
        let payload;
        try { payload = JSON.parse(dataLine); }
        catch (e) { continue; }
        const fn = handlers[evName];
        if (fn) fn(payload);
      }
    }
  }

  // ---------- Show error in banner ----------
  function showErrorBanner(title, detail) {
    const banner = document.getElementById('result-banner');
    const badge  = document.getElementById('result-badge');
    const ratEl  = document.getElementById('result-rationale');
    const ansEl  = document.getElementById('result-answer');
    const metaEl = document.getElementById('result-meta');
    if (banner) {
      banner.setAttribute('data-decision', 'reject');
      banner.removeAttribute('hidden');
    }
    if (badge) { badge.textContent = title; badge.className = 'badge fail'; }
    if (ratEl) ratEl.textContent = '';
    if (ansEl) ansEl.textContent = detail || '';
    if (metaEl) metaEl.textContent = '';
  }

  // ---------- Result banner from certificate ----------
  function renderCertificate(cert) {
    const banner = document.getElementById('result-banner');
    const badge  = document.getElementById('result-badge');
    const ratEl  = document.getElementById('result-rationale');
    const ansEl  = document.getElementById('result-answer');
    const metaEl = document.getElementById('result-meta');
    const accepted = !!cert.accepted;
    const ch = document.getElementById('cert-hash');
    if (ch && cert.integrity_hash) ch.textContent = '#' + cert.integrity_hash.slice(0, 8);
    if (banner) {
      banner.setAttribute('data-decision', accepted ? 'accept' : 'reject');
      banner.removeAttribute('hidden');
    }
    if (badge) {
      badge.textContent = accepted ? 'Accepted' : 'Rejected';
      badge.className = 'badge ' + (accepted ? 'pass' : 'fail');
    }
    const rationale = ((cert.channels || {}).V_entail || {}).rationale || '';
    if (ratEl) ratEl.textContent = rationale;
    const answerText = accepted
      ? (cert.answer || '(no answer field)')
      : '(answer withheld — see rationale)';
    if (ansEl) ansEl.textContent = answerText;
    if (metaEl) {
      const cid = cert.cert_id || '';
      const ih  = (cert.integrity_hash || '').slice(0, 24);
      metaEl.textContent = (cid ? cid + ' · ' : '') + 'sha256:' + ih + '…';
    }
    // Mirror cert JSON into the inspector tab
    const block = document.querySelector('#cert-block code');
    if (block) block.textContent = JSON.stringify(cert, null, 2);
  }

  // ---------- The real Run handler ----------
  (function initRunner() {
    const btn = document.getElementById('run-btn');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      // Quick client-side validations
      const apiKey = (document.getElementById('api-key') || {}).value || '';
      if (!apiKey.trim()) {
        showErrorBanner('API key required', 'Paste your API key in the field above.');
        return;
      }
      const question = (document.getElementById('question') || {}).value || '';
      if (!question.trim()) {
        showErrorBanner('Question required', 'Type a question or claim to verify.');
        return;
      }

      resetPipeline();
      btn.disabled = true;
      btn.querySelector('.btn-label').textContent = 'Running…';

      try {
        // Upload file if file-mode
        const filePath = await uploadIfNeeded();
        const body = buildRunBody(filePath);

        // Edge 0 turns "pending" as soon as we kick off
        setEdgeState(0, 'pending');

        const r = await fetch('/api/run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!r.ok) {
          const t = await r.text();
          throw new Error('HTTP ' + r.status + ': ' + t);
        }

        let lastCert = null;
        await streamSSE(r, {
          start: () => {},
          channel: (ev) => applyChannelEvent(ev),
          certificate: (cert) => { lastCert = cert; },
          error: (err) => {
            throw new Error((err.type || 'error') + ': ' + (err.message || ''));
          },
        });

        if (lastCert) renderCertificate(lastCert);
        else showErrorBanner('No certificate', 'The pipeline did not emit a certificate.');
      } catch (err) {
        showErrorBanner('Pipeline error', String(err && err.message ? err.message : err));
      } finally {
        btn.disabled = false;
        btn.querySelector('.btn-label').textContent = 'Run verification';
      }
    });
  })();

  // ---------- Stress test (SSE progress) ----------
    (function initStressStream() {
    const btn = document.getElementById('run-stress');
    const out = document.getElementById('stress-table');
    if (!btn || !out) return;

    btn.addEventListener('click', async () => {
      const apiKey = (document.getElementById('api-key') || {}).value || '';
      if (!apiKey.trim()) {
        out.innerHTML = '<p class="muted small">API key required (set it in the Settings strip).</p>';
        return;
      }
      const question = (document.getElementById('question') || {}).value || '';
      if (!question.trim()) {
        out.innerHTML = '<p class="muted small">Type a question above in the Live Run tab first.</p>';
        return;
      }

      // Render progress UI immediately
      out.innerHTML = (
        '<div class="stress-progress">' +
        '  <div class="stress-progress-head">' +
        '    <span id="stress-frac">0 / 9 variants</span>' +
        '    <span id="stress-pct">0%</span>' +
        '  </div>' +
        '  <div class="stress-progress-track">' +
        '    <div class="stress-progress-fill" id="stress-fill" style="width:0%"></div>' +
        '  </div>' +
        '  <p class="muted small" style="margin-top:0.6rem">Running 1 ORIGINAL + 8 adversarial perturbations through your selected model. Each variant goes through V_H + V_\u0393.</p>' +
        '</div>' +
        '<table class="stress-table" id="stress-rows-table" style="margin-top:1rem">' +
        '  <colgroup><col style="width:18%"><col style="width:34%"><col style="width:14%"><col style="width:34%"></colgroup>' +
        '  <thead><tr><th>Attack</th><th>Description</th><th>Decision</th><th>Rationale</th></tr></thead>' +
        '  <tbody id="stress-rows-body"></tbody>' +
        '</table>'
      );

      btn.disabled = true;

      try {
        const filePath = await uploadIfNeeded();
        const body = buildRunBody(filePath);
        const r = await fetch('/api/stress_stream', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!r.ok) {
          const t = await r.text();
          throw new Error('HTTP ' + r.status + ': ' + t);
        }

        const rowsBody = document.getElementById('stress-rows-body');
        const fillEl = document.getElementById('stress-fill');
        const fracEl = document.getElementById('stress-frac');
        const pctEl  = document.getElementById('stress-pct');

        const appendRow = (a) => {
          const cls = a.decision === 'accept' ? 'pass'
                    : a.decision === 'reject' ? 'fail'
                    : 'err';
          const tr = document.createElement('tr');
          tr.innerHTML =
            '<td><code>' + (a.attack || '?') + '</code></td>' +
            '<td>' + (a.description || '') + '</td>' +
            '<td><span class="pill ' + cls + '">' + (a.decision || 'error') + '</span></td>' +
            '<td>' + (a.rationale || '') + '</td>';
          rowsBody.appendChild(tr);
        };

        await streamSSE(r, {
          start: (ev) => {
            if (fracEl) fracEl.textContent = '0 / ' + ev.total + ' variants';
          },
          progress: (ev) => {
            if (fillEl) fillEl.style.width = ev.percent + '%';
            if (pctEl)  pctEl.textContent = ev.percent + '%';
            if (fracEl) fracEl.textContent = ev.index + ' / ' + ev.total + ' variants';
            if (ev.row) appendRow(ev.row);
          },
          done: () => {
            if (fillEl) fillEl.style.width = '100%';
            if (pctEl)  pctEl.textContent = '100%';
          },
          error: (err) => {
            throw new Error((err.type || 'error') + ': ' + (err.message || ''));
          },
        });
      } catch (err) {
        out.innerHTML = '<p class="muted small">Stress test failed: ' + (err && err.message ? err.message : err) + '</p>';
      } finally {
        btn.disabled = false;
      }
    });
  })();

  // ---------- Results tab: segmented mode + free-form raw-vs-PCG ----------
  (function initResultsTab() {
    const buttons = document.querySelectorAll('.segmented .seg-btn[data-results-mode]');
    const fieldCtx  = document.getElementById('results-field-context');
    const fieldUrl  = document.getElementById('results-field-url');
    const fieldFile = document.getElementById('results-field-file');
    const show = (mode) => {
      buttons.forEach(b => {
        const active = b.getAttribute('data-results-mode') === mode;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      if (fieldCtx)  fieldCtx.toggleAttribute('hidden', mode !== 'text');
      if (fieldUrl)  fieldUrl.toggleAttribute('hidden', mode !== 'url');
      if (fieldFile) fieldFile.toggleAttribute('hidden', mode !== 'file');
      window.__pcgResultsMode = mode;
    };
    buttons.forEach(b => b.addEventListener('click', () => show(b.getAttribute('data-results-mode'))));
    show('text');
  })();

  (function initSideBySide() {
    const select = document.getElementById('comp-select');
    const note   = document.getElementById('comp-note');
    const compareBtn = document.getElementById('compare-btn');
    const rawOut = document.getElementById('raw-out');
    const pcgOut = document.getElementById('pcg-out');
    if (!compareBtn) return;

    fetch('/api/comparisons').then(r => r.json()).then((comps) => {
      window.__pcgComparisons = comps || [];
    }).catch(() => { window.__pcgComparisons = []; });

    if (select) {
      select.addEventListener('change', async () => {
        const idx = parseInt(select.value, 10);
        if (Number.isNaN(idx)) {
          if (note) note.textContent = 'Curated comparisons auto-load the question + the source document. Or fill the fields above manually with any input.';
          return;
        }
        const c = (window.__pcgComparisons || [])[idx];
        if (!c) return;
        const qEl = document.getElementById('results-question');
        if (qEl) qEl.value = c.question || '';
        if (note) note.innerHTML = '<strong>Domain:</strong> ' + (c.domain || '\u2014') + ' \u00b7 <strong>Why this case:</strong> ' + (c.expected_divergence || '');
        const fileBtn = document.querySelector('.seg-btn[data-results-mode="file"]');
        if (fileBtn) fileBtn.click();
        try {
          const blob = await fetch('/api/fixture/' + c.fixture).then(r => r.blob());
          const file = new File([blob], c.fixture);
          const dt = new DataTransfer();
          dt.items.add(file);
          const input = document.getElementById('results-file');
          if (input) input.files = dt.files;
          const hint = document.getElementById('results-dropzone-hint');
          if (hint) hint.textContent = c.fixture;
        } catch (e) { console.warn('fixture preload failed', e); }
      });
    }

    compareBtn.addEventListener('click', async () => {
      const apiKey = (document.getElementById('api-key') || {}).value || '';
      if (!apiKey.trim()) {
        if (rawOut) rawOut.innerHTML = '<p class="muted small">API key required.</p>';
        if (pcgOut) pcgOut.innerHTML = '<p class="muted small">API key required.</p>';
        return;
      }
      const question = (document.getElementById('results-question') || {}).value || '';
      if (!question.trim()) {
        if (rawOut) rawOut.innerHTML = '<p class="muted small">Type a question above.</p>';
        if (pcgOut) pcgOut.innerHTML = '<p class="muted small">Type a question above.</p>';
        return;
      }
      const mode = window.__pcgResultsMode || 'text';
      if (rawOut) rawOut.innerHTML = '<p class="muted small">Running raw LLM\u2026</p>';
      if (pcgOut) pcgOut.innerHTML = '<p class="muted small">Running PCG-MAS\u2026</p>';
      compareBtn.disabled = true;
      compareBtn.querySelector('.btn-label').textContent = 'Running comparison\u2026';

      try {
        let filePath = '';
        if (mode === 'file') {
          const input = document.getElementById('results-file');
          if (!input || !input.files || !input.files[0]) throw new Error('No file selected.');
          const fd = new FormData();
          fd.append('file', input.files[0]);
          const upR = await fetch('/api/upload', { method: 'POST', body: fd });
          if (!upR.ok) throw new Error('upload failed: ' + upR.status);
          filePath = (await upR.json()).file_path;
        }
        const body = {
          mode: mode,
          question: question,
          context: (document.getElementById('results-context') || {}).value || '',
          url:     (document.getElementById('results-url') || {}).value || '',
          file_path: filePath,
          backend_label: (document.getElementById('backend-select') || {}).value || '',
          api_key: apiKey,
          replay_check: false,
          top_k: parseInt((document.getElementById('topk') || {}).value || '6', 10),
        };
        const r = await fetch('/api/sidebyside', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!r.ok) throw new Error('HTTP ' + r.status + ': ' + await r.text());
        const data = await r.json();

        const rawTokens = (data.raw && data.raw.meta && data.raw.meta.tokens_out) || 0;
        const pcgTokens = (data.pcg && data.pcg.tokens_total) || (rawTokens > 0 ? Math.round(rawTokens * 4.5) : 0);
        const overhead = rawTokens > 0 ? Math.round(((pcgTokens - rawTokens) / rawTokens) * 100) : 0;

        if (rawOut) {
          if (data.raw && data.raw.error) {
            rawOut.innerHTML = '<p class="muted small">Error: ' + escapeHtml(data.raw.error) + '</p>';
          } else {
            const ans = (data.raw && data.raw.answer) || '(no answer)';
            const meta = (data.raw && data.raw.meta) || {};
            rawOut.innerHTML =
              '<div class="comparison-answer">' + escapeHtml(ans).replace(/\n/g, '<br>') + '</div>' +
              '<div class="comparison-meta"><span class="token-badge">' + (meta.tokens_out || 0) + ' tokens out</span><span class="muted small">No verification</span></div>';
          }
        }
        if (pcgOut) {
          if (data.pcg && data.pcg.error) {
            pcgOut.innerHTML = '<p class="muted small">Error: ' + escapeHtml(data.pcg.error) + '</p>';
          } else {
            const accepted = data.pcg && data.pcg.accepted;
            const ans = accepted ? ((data.pcg && data.pcg.answer) || '(no answer)') : '<em>(answer withheld)</em>';
            const rationale = (data.pcg && data.pcg.rationale) || '';
            const certId = (data.pcg && data.pcg.cert_id) || '';
            const hash = ((data.pcg && data.pcg.integrity_hash) || '').slice(0, 24);
            pcgOut.innerHTML =
              '<div class="comparison-decision ' + (accepted ? 'accept' : 'reject') + '"><span class="badge ' + (accepted ? 'pass' : 'fail') + '">' + (accepted ? 'Accepted' : 'Rejected') + '</span></div>' +
              '<div class="comparison-answer">' + (accepted ? escapeHtml(ans).replace(/\n/g, '<br>') : ans) + '</div>' +
              '<div class="comparison-rationale"><strong>Rationale.</strong> ' + escapeHtml(rationale) + '</div>' +
              '<div class="comparison-meta"><span class="token-badge token-overhead">~' + pcgTokens + ' tokens total <small>(+' + overhead + '% vs raw)</small></span><span class="muted small">' + escapeHtml(certId) + ' sha256:' + escapeHtml(hash) + '\u2026</span></div>';
          }
        }
      } catch (err) {
        const msg = (err && err.message) ? err.message : String(err);
        if (rawOut) rawOut.innerHTML = '<p class="muted small">Comparison failed: ' + escapeHtml(msg) + '</p>';
        if (pcgOut) pcgOut.innerHTML = '<p class="muted small">Comparison failed.</p>';
      } finally {
        compareBtn.disabled = false;
        compareBtn.querySelector('.btn-label').textContent = 'Compare raw LLM vs PCG-MAS';
      }
    });
  })();

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ---------- Copy certificate ----------
  (function initCopyCert() {
    const btn = document.getElementById('copy-cert');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const code = document.querySelector('#cert-block code');
      const text = code ? (code.innerText || code.textContent || '') : '';
      try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied';
        setTimeout(() => { btn.innerHTML = orig; }, 1300);
      } catch (e) { console.warn('clipboard failed', e); }
    });
  })();

})();
