{
  "backends": [
    {
      "dtype": "float16",
      "kind": "hf_local",
      "model_name": "microsoft/Phi-3.5-mini-instruct"
    },
    {
      "dtype": "float16",
      "kind": "hf_local",
      "model_name": "Qwen/Qwen2.5-7B-Instruct"
    }
  ],
  "checker": {
    "entailment": "exact_match"
  },
  "configurations": [
    {
      "enable_pcg": false,
      "name": "baseline_no_pcg"
    },
    {
      "enable_pcg": true,
      "k": 1,
      "name": "pcg_k1"
    },
    {
      "enable_pcg": true,
      "k": 2,
      "name": "pcg_k2"
    },
    {
      "enable_pcg": true,
      "k": 4,
      "name": "pcg_k4"
    }
  ],
  "dataset": {
    "n_examples": 100,
    "name": "hotpotqa",
    "split": "validation"
  },
  "output_dir": "results/r5",
  "prover": {
    "max_answer_tokens": 64,
    "retriever": "bm25",
    "temperature": 0.0,
    "top_k": 4
  }
}